APP_NAME=DCapple
STORE_PHONE="+233 54 409 6292"
STORE_PHONE_TEL=+233544096292
STORE_EMAIL="support@dcapple.com"
STORE_WELCOME_PREFIX="Welcome to"

# Free standard delivery when cart subtotal (after promo by default) reaches this amount (GHS). See config/delivery.php.
STORE_FREE_SHIPPING_MIN=100
# DELIVERY_FREE_MIN_SUBTOTAL=100
# DELIVERY_FREE_COMPARE=after_promo
# DELIVERY_PER_UNIT_FEE_REDUCTION=0
# DELIVERY_PER_UNIT_MAX_RATIO=0.5
# DELIVERY_EXPRESS_WHEN_STANDARD_FREE=surcharge_only

APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# LAN development: run `composer run serve:lan` (or `php artisan serve --host=0.0.0.0`) and open http://YOUR_LAN_IP:8000 on other devices on the same Wi‑Fi.
# If you use `npm run dev` / Vite from another device, set this to your Mac’s LAN IP (same as in the browser bar, without http).
# VITE_DEV_SERVER_HOST=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=dcapple_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="support@dcapple.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# SMS (Arkesel / Hubtel / log). Ghana numbers normalized to +233…
SMS_NOTIFICATIONS_ENABLED=false
SMS_PROVIDER=log
SMS_API_KEY=
SMS_SENDER=DCAPPLE
# SMS_ARKESEL_URL=https://sms.arkesel.com/sms/api
# SMS_HUBTEL_CLIENT_ID=
# SMS_HUBTEL_CLIENT_SECRET=
# SMS_HUBTEL_SEND_URL=https://sms.hubtel.com/v1/messages/send

# WhatsApp via Twilio (optional). SMS still works if WhatsApp fails or is off.
WHATSAPP_NOTIFICATIONS_ENABLED=false
WHATSAPP_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
